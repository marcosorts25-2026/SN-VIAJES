{
  "name": "somos-noche-transporte",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "main": "public/electron-main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5000",
    "generate-icons": "node scripts/generate-icons.mjs",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "npm run generate-icons && vite build --base ./ && electron-builder",
    "electron-build-win": "npm run generate-icons && vite build --base ./ && electron-builder --win --publish never"
  },
  "dependencies": {
    "firebase": "^9.23.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "optionalDependencies": {
    "javascript-lp-solver": "^0.4.24"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2",
    "vite": "^5.1.0",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.somosnochetransporte.app",
    "productName": "SOMOS NOCHE TRANSPORTE",
    "files": [
      "dist/**/*",
      "public/electron-main.cjs",
      "public/icons/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public/icons",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icons/installer.ico",
      "uninstallerIcon": "public/icons/installer.ico",
      "shortcutName": "SOMOS NOCHE TRANSPORTE"
    }
  }
}
